  },
  "homepage": "https://github.com/PostQDev/postq-sdk-all/tree/main/sdks/js#readme",
  "bugs": {
    "url": "https://github.com/PostQDev/postq-sdk-all/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  }
}
