{
  "name": "@postq/sdk",
  "version": "0.1.0",
  "description": "Official PostQ SDK for JavaScript/TypeScript — quantum-safe cryptography for your applications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
